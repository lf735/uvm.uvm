# =============================================================
# .gitignore — UVM SV Transpiler Suite (Python + SystemVerilog)
# =============================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distributions / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
junit*.xml

# Type checkers
.mypy_cache/
.dmypy.json
.pytype/
.pyre/

# ---------------------------------------------------------------------------
# Project-specific
# ---------------------------------------------------------------------------

# Backup files created by the transpiler (in-place backup)
*.sv.bak

# JSON reports generated by --report
*.json
!tests/fixtures/**/*.json

# Lark cache
*.lark.cache

# ---------------------------------------------------------------------------
# Editors & IDEs
# ---------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, CLion…)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.Trash-*

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
